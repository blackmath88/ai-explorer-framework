{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-exercise.json",
  "title": "Exercise",
  "type": "object",
  "required": ["id", "title", "objective", "instructions", "expected_output", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ex-[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "instructions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "expected_output": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "required": ["difficulty", "estimated_minutes", "status", "tags"],
      "properties": {
        "difficulty": {
          "type": "string",
          "enum": ["intro", "intermediate", "advanced"]
        },
        "estimated_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "published", "archived"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
